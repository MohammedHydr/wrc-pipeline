# ── Target site ──────────────────────────────────────────────────────────────
WRC_BASE_URL=https://www.workplacerelations.ie
# GET endpoint the advanced-search form redirects to (see docs/recon/wrc-search.md)
WRC_SEARCH_PATH=/en/search/
# The four decision bodies; override per run with -a bodies=
WRC_BODIES=Employment Appeals Tribunal,Equality Tribunal,Labour Court,Workplace Relations Commission
# Body name -> body= query code, taken from the site's checkbox values
WRC_BODY_CODES=Employment Appeals Tribunal=2,Equality Tribunal=1,Labour Court=3,Workplace Relations Commission=15376
# Results per listing page, as the site paginates
WRC_RESULTS_PER_PAGE=10
# Date format of the from=/to= query params (DD/MM/YYYY)
WRC_DATE_FORMAT=%d/%m/%Y

# ── Partitioning ─────────────────────────────────────────────────────────────
# daily | weekly | monthly — see ARCHITECTURE.md for why monthly is the default
PARTITION_SIZE=monthly

# ── Scrapy politeness / rate limiting ────────────────────────────────────────
# AutoThrottle finds the fastest polite rate; the caps below are hard limits.
CONCURRENT_REQUESTS=8
CONCURRENT_REQUESTS_PER_DOMAIN=4
# Base delay (seconds) between requests; AutoThrottle scales from here
DOWNLOAD_DELAY=0.25
AUTOTHROTTLE_ENABLED=true
AUTOTHROTTLE_START_DELAY=0.5
# How far AutoThrottle may back off when the server slows down
AUTOTHROTTLE_MAX_DELAY=15
AUTOTHROTTLE_TARGET_CONCURRENCY=4
# Retries for transient failures only (408/429/5xx + network); 4xx never retried
RETRY_TIMES=4
DOWNLOAD_TIMEOUT=60
ROBOTSTXT_OBEY=true
# Dev-only response cache; keep false for real runs so change detection is honest
HTTP_CACHE_ENABLED=false
# The whole flow is stateless GET — cookies are pure overhead
COOKIES_ENABLED=false
# Abort downloads over max (256 MiB, logged as a failure); warn at 32 MiB
DOWNLOAD_MAXSIZE=268435456
DOWNLOAD_WARNSIZE=33554432
# Truthful UA — add your contact, e.g.:
# USER_AGENT=legal-research-pipeline/1.0 (+mailto:you@example.com)
# Dir to resume an interrupted backfill (scrapy JOBDIR). Leave empty for normal
# runs — a stale JOBDIR filters out requests and breaks the run accounting.
JOBDIR=
# Thread pool for blocking Mongo/S3 I/O in the pipelines; raise for many sources
REACTOR_THREADPOOL_MAXSIZE=10

# ── MongoDB ──────────────────────────────────────────────────────────────────
# 27018 to avoid clashing with a locally installed Mongo; keep MONGO_PORT in sync
MONGO_URI=mongodb://root:example@localhost:27018
MONGO_DB=wrc
# One collection per concern (see docs/data-model.md)
MONGO_LANDING_COLLECTION=landing_document_versions
MONGO_STATE_COLLECTION=document_state
MONGO_CURATED_COLLECTION=curated_documents
MONGO_ENRICHED_COLLECTION=enriched_decisions
MONGO_RUN_LOG_COLLECTION=run_logs
# docker-compose provisioning only — must match the credentials in MONGO_URI
MONGO_ROOT_USER=root
MONGO_ROOT_PASSWORD=example
MONGO_PORT=27018
# mongo-express web UI: http://localhost:8081
MONGO_EXPRESS_PORT=8081
MONGO_EXPRESS_USER=admin
MONGO_EXPRESS_PASSWORD=admin

# ── Object storage (MinIO / S3-compatible) ───────────────────────────────────
# Point at real S3 by changing these — no code change needed
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_REGION=us-east-1
# Two zones: landing = append-only raw truth, curated = latest-only clean view
S3_LANDING_BUCKET=wrc-landing
S3_CURATED_BUCKET=wrc-curated
# Host ports (docker-compose only)
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# ── Behaviour toggles ────────────────────────────────────────────────────────
# true = skip identifiers already in Mongo (faster, but no change detection)
SKIP_EXISTING_IDENTIFIERS=false
# Re-fetch known documents with If-None-Match; a 304 = unchanged, zero bytes
USE_CONDITIONAL_REQUESTS=true
# Legacy pages (Equality Tribunal ~2000-2003, old EAT) embed the decision as a
# PDF — follow it and store the PDF byte-for-byte instead of the HTML wrapper
FOLLOW_EMBEDDED_PDF=true
# Chrome PDFs present on every page — never decisions, always skipped
EMBEDDED_PDF_EXCLUDE=cookie_policy.pdf,decisions_information_guide.pdf
# Path markers for legacy decision PDFs whose filename lacks the identifier
EMBEDDED_PDF_PATH_MARKERS=_import/,database-of-decisions

# ── Transformation / enrichment ──────────────────────────────────────────────
# CSS selectors tried in order to find the decision content (keep unquoted)
HTML_CONTENT_SELECTORS=#main, main, article, .article-body, .content, #content
# Page chrome stripped before selecting content
HTML_DROP_SELECTORS=.cookie-banner, .cookie-consent, .cookies, .breadcrumb, .breadcrumbs, .social-share, .share-tools, .document-actions, .page-actions, .return-to-search, .print-controls
# A selector match under this many visible chars is rejected as "not the content"
HTML_MIN_TEXT_CHARS=200
# lxml (fast) or html.parser (pure-Python fallback)
HTML_PARSER=lxml
# Worker threads for transform/enrich (I/O-bound); 1 = sequential
TRANSFORM_WORKERS=8

# Log level for the structured JSON logs
LOG_LEVEL=INFO
