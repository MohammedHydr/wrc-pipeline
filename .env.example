# ── Target site ──────────────────────────────────────────────────────────────
# Root of the scraped site; also becomes each record's `source` (its netloc).
# Used by: spider URL building, natural key (source, body, identifier).
WRC_BASE_URL=https://www.workplacerelations.ie
# GET search endpoint the advanced-search form 302-redirects to (recon:
# docs/recon/wrc-search.md). Used by: spider search requests.
WRC_SEARCH_PATH=/en/search/
# The four decision bodies the assessment requires. Used by: spider fan-out
# (one crawl stream per body × partition); override per run with -a bodies=.
WRC_BODIES=Employment Appeals Tribunal,Equality Tribunal,Labour Court,Workplace Relations Commission
# Body -> numeric body= query code, read from the site's checkbox `value`
# attributes during recon (NOT a 1-4 index — WRC is 15376). In config so a
# site change is a one-line edit, not a code change.
WRC_BODY_CODES=Employment Appeals Tribunal=2,Equality Tribunal=1,Labour Court=3,Workplace Relations Commission=15376
# Results per listing page — measured on the site ("Shows 1 to 10 of N").
# Used by: pagination math (pages = ceil(N / this)) and listing-loss
# accounting when a page request fails.
WRC_RESULTS_PER_PAGE=10
# Date format of the from=/to= query params, as the site emits them
# (DD/MM/YYYY with literal slashes). Used by: spider search URL building.
WRC_DATE_FORMAT=%d/%m/%Y

# ── Partitioning ─────────────────────────────────────────────────────────────
# monthly | weekly | daily. Monthly = ~100-300 records (5-30 listing pages)
# per body in recent years: big enough to amortise request overhead, small
# enough that a failed partition retries cheaply (see ARCHITECTURE.md).
# Used by: config/common.py:iter_partitions(); per-run override: -a partition=.
PARTITION_SIZE=monthly

# ── Scrapy politeness / anti-blocking ────────────────────────────────────────
# All consumed by scraper/wrc_scraper/settings.py. Strategy: AutoThrottle
# finds the fastest polite rate; fixed bounds below are the hard ceiling.
# Global in-flight request cap. 8 = keeps the pipeline busy while staying
# far below anything that looks like a flood for a single-domain crawl.
CONCURRENT_REQUESTS=8
# Per-domain cap — the real politeness bound (everything here is one domain).
# 4 parallel requests is a common "considerate crawler" ceiling.
CONCURRENT_REQUESTS_PER_DOMAIN=4
# Base delay (seconds) between requests to the same slot; AutoThrottle scales
# it up/down from here. 0.25s ≈ max 4 req/s before throttling kicks in.
DOWNLOAD_DELAY=0.25
# Adapts delay/concurrency to observed server latency: speeds up while the
# server is healthy, backs off on slowdowns — "fastest without getting
# blocked" without hand-tuning.
AUTOTHROTTLE_ENABLED=true
# First-request delay before latency is known. 0.5s = start gently, let
# AutoThrottle earn the speed-up from real measurements.
AUTOTHROTTLE_START_DELAY=0.5
# Ceiling AutoThrottle may back off to when the server struggles. 15s keeps a
# stalled site from freezing the crawl entirely while still yielding hard.
AUTOTHROTTLE_MAX_DELAY=15
# Average parallelism AutoThrottle aims for; matches the per-domain cap so
# the two limits agree instead of fighting.
AUTOTHROTTLE_TARGET_CONCURRENCY=4
# Retries per request for transient failures only (408/429/5xx + network
# errors — see RETRY_HTTP_CODES in scrapy settings). 4 survives a brief
# outage; terminal 4xx are recorded immediately, never retried.
RETRY_TIMES=4
# Seconds before an unresponsive download is abandoned (then retried/recorded).
# 60s tolerates slow legacy PDFs without letting a dead socket hang a slot.
DOWNLOAD_TIMEOUT=60
# Politeness policy is the hard speed limit (CLAUDE.md): robots.txt is obeyed.
# The robots-forbidden legacy PDF paths fall back to storing the permitted
# HTML case page instead.
ROBOTSTXT_OBEY=true
# Local response cache (1h TTL) for development iteration on selectors —
# avoids re-hitting the live site. Keep false for real runs so change
# detection sees fresh content.
HTTP_CACHE_ENABLED=false
# The whole flow is stateless GET (recon: no session cookie needed), so the
# cookie middleware is pure per-request overhead. Off.
COOKIES_ENABLED=false
# Memory guards (bytes): documents are buffered in RAM before hashing/upload.
# Over max (256 MiB) = download cancelled + recorded as an auditable failure;
# warnsize (32 MiB) only logs. Largest observed decision is well under both;
# raise via env if a legitimately larger document ever appears.
DOWNLOAD_MAXSIZE=268435456
DOWNLOAD_WARNSIZE=33554432
# Truthful UA with a project identifier (politeness policy: no stealth). Set
# your contact so the site operator can reach you, e.g.:
# USER_AGENT=legal-research-pipeline/1.0 (+mailto:you@example.com)
# Resume an *interrupted* long backfill: point at a dir to persist scheduler +
# dupefilter state (scrapy JOBDIR). Keep empty for normal runs — a stale
# JOBDIR dupe-filters every document request and breaks found/scraped
# reconciliation on a fresh rerun.
JOBDIR=
# Twisted reactor thread pool. The item pipelines run their blocking Mongo/S3
# I/O on this pool (deferToThread), and DNS resolution uses it too — so it
# bounds item-processing parallelism. 10 (Scrapy default) comfortably covers
# 4-concurrent downloads; raise toward 20+ for many-host crawls (50+ sources).
REACTOR_THREADPOOL_MAXSIZE=10

# ── MongoDB ──────────────────────────────────────────────────────────────────
# Connection string for all metadata reads/writes (spider pipelines,
# transform, enrichment, run logs). 27018 (not 27017) to avoid colliding
# with any locally installed MongoDB; must match MONGO_PORT below.
MONGO_URI=mongodb://root:example@localhost:27018
# One database, one collection per concern (see docs/data-model.md):
MONGO_DB=wrc
# immutable landing versions (append-only, unique version index)
MONGO_LANDING_COLLECTION=landing_document_versions
# mutable "latest version" pointer, one row per document (dedup reads this)
MONGO_STATE_COLLECTION=document_state
# latest-only curated records with lineage to landing
MONGO_CURATED_COLLECTION=curated_documents
# business-layer structured extraction (citation graph, facets, outcomes)
MONGO_ENRICHED_COLLECTION=enriched_decisions
# one summary document per crawl (reconciliation evidence)
MONGO_RUN_LOG_COLLECTION=run_logs
# Consumed only by docker-compose to provision the container; the app reads
# credentials from MONGO_URI above (keep the two in sync).
MONGO_ROOT_USER=root
MONGO_ROOT_PASSWORD=example
MONGO_PORT=27018
# mongo-express web UI (docker-compose only): http://localhost:8081 —
# browser access to the collections without a desktop client.
MONGO_EXPRESS_PORT=8081
MONGO_EXPRESS_USER=admin
MONGO_EXPRESS_PASSWORD=admin

# ── Object storage (MinIO / S3-compatible) ───────────────────────────────────
# Used by all boto3 clients (spider storage pipeline, transform, enrichment)
# and docker-compose. Point at real S3/another endpoint = no code change.
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
# Required by the S3 API; MinIO accepts any region, us-east-1 is the default.
S3_REGION=us-east-1
# Two buckets = two zones: landing is append-only raw truth, curated is the
# derived latest-only view. Also created by docker-compose's minio-init.
S3_LANDING_BUCKET=wrc-landing
S3_CURATED_BUCKET=wrc-curated
# Host ports for the MinIO API and web console (docker-compose only).
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001

# ── Behaviour toggles ────────────────────────────────────────────────────────
# true = don't even re-download identifiers already in Mongo (fast, but skips
# change detection for those records). false = re-fetch, hash-compare, only
# re-upload/update when changed (default; matches requirement 9).
SKIP_EXISTING_IDENTIFIERS=false

# The search endpoint links every result to an HTML case page, but the earliest
# legacy imports (Equality Tribunal ~2000-2003, EAT legacy) embed the decision
# as a PDF inside that page. true = follow that embedded PDF and store it
# byte-for-byte as the authoritative artifact (robots-forbidden PDF paths fall
# back to the HTML wrapper); false = always store the HTML.
FOLLOW_EMBEDDED_PDF=true
# PDF links that are site chrome on every page (never a decision), skipped when
# following. Matched case-insensitively against the link.
EMBEDDED_PDF_EXCLUDE=cookie_policy.pdf,decisions_information_guide.pdf
# Path substrings that mark a legacy decision PDF whose filename lacks the
# identifier (e.g. EAT's GUID-named PDFs under /eat_import/).
EMBEDDED_PDF_PATH_MARKERS=_import/,database-of-decisions

# ── Transformation / enrichment ──────────────────────────────────────────────
# Ordered CSS selectors tried in turn to isolate the relevant legal-document
# content (first match with enough text wins). Used by the HTML canonicalizer
# (content hashing) and the curated transform.
# NOTE: keep unquoted — quoted values behave differently between dotenv parsers.
HTML_CONTENT_SELECTORS=#main, main, article, .article-body, .content, #content
# Source-specific page chrome removed before selecting document content.
HTML_DROP_SELECTORS=.cookie-banner, .cookie-consent, .cookies, .breadcrumb, .breadcrumbs, .social-share, .share-tools, .document-actions, .page-actions, .return-to-search, .print-controls
# Minimum visible characters for a selector match to count as "the content" —
# 200 rejects near-empty wrappers (a real decision is far longer) and trips
# the fallback instead of silently storing chrome.
HTML_MIN_TEXT_CHARS=200
# BeautifulSoup backend: lxml (C, fast, lenient; already a Scrapy dependency)
# or html.parser (pure-Python portable fallback).
HTML_PARSER=lxml
# Worker threads for the transform and enrichment steps. Both are I/O-bound
# (S3 GET/PUT + Mongo round-trips per record), so 8 threads overlap that
# latency well on local Docker; pymongo/botocore clients are thread-safe.
# Set 1 for fully sequential processing.
TRANSFORM_WORKERS=8

# Root log level for the structured JSON logs (DEBUG for troubleshooting).
LOG_LEVEL=INFO
